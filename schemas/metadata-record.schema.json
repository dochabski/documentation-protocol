{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "SPDX-License-Identifier: CC0-1.0",
  "title": "Documentation Protocol Metadata Record",
  "type": "object",
  "required": ["metadata"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["title", "short_description", "artifact_type", "version", "authors", "license", "repository_url", "keywords", "maintenance_status"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "short_description": {"type": "string", "minLength": 1},
        "artifact_type": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "authors": {"type": "array", "minItems": 1},
        "contributors": {"type": "array"},
        "orcid_ids": {"type": "array"},
        "organizations": {"type": "array"},
        "license": {"type": "string", "minLength": 1},
        "code_license": {"type": "string"},
        "license_notes": {"type": "string"},
        "third_party_materials": {"type": "array"},
        "downstream_reuse_constraints": {"type": "array"},
        "ai_indexing_training_preference": {"type": "string"},
        "repository_url": {"type": "string", "minLength": 1},
        "archive_doi": {"type": "string"},
        "keywords": {"type": "array", "minItems": 1},
        "related_publication": {"type": "string"},
        "related_artifacts": {"type": "array"},
        "dependencies": {"type": "array"},
        "runtime_environment": {"type": "object"},
        "funding": {"type": "array"},
        "maintenance_status": {
          "type": "string",
          "enum": ["draft", "active", "stable", "deprecated", "superseded", "archived"]
        }
      }
    }
  }
}
